    private double calculatePrice(DeliveryRequestDto req) {
        return req.getWeight() * 10;
    }
    
    
    @Autowired
    private EventProducer producer;

    public Delivery updateStatus(Long id, DeliveryStatus status) {

        Delivery delivery = repo.findById(id)
                .orElseThrow(() -> new RuntimeException("Not found"));

        delivery.setStatus(status);
        Delivery updated = repo.save(delivery);

        //sending event
        TrackingEventDto event = new TrackingEventDto();
        event.setDeliveryId(updated.getId());
        event.setUserId(updated.getUserId());
        event.setStatus(status.name());
        event.setLocation("System");
        event.setDescription("Status updated to " + status.name());

        producer.sendEvent(event);

        return updated;
    }

    private void validateTransition(DeliveryStatus current, DeliveryStatus next) {

        if (current == DeliveryStatus.BOOKED && next != DeliveryStatus.PICKED_UP)
            throw new RuntimeException("Invalid transition");

        if (current == DeliveryStatus.PICKED_UP && next != DeliveryStatus.IN_TRANSIT)
            throw new RuntimeException("Invalid transition");

        if (current == DeliveryStatus.IN_TRANSIT && next != DeliveryStatus.OUT_FOR_DELIVERY)
            throw new RuntimeException("Invalid transition");

        if (current == DeliveryStatus.OUT_FOR_DELIVERY && next != DeliveryStatus.DELIVERED)
            throw new RuntimeException("Invalid transition");
    }
    
    public List<Delivery> getAllDeliveries() {
        return repo.findAll();
    }
    

}
