	}



     
    public Delivery createDelivery(DeliveryRequestDto req, String userId) {

       
        Parcel pkg=new Parcel();
        pkg.setWeight(req.getWeight());
        pkg.setType(req.getType());

        Delivery d = new Delivery();
        d.setUserId(userId);
        d.setStatus(DeliveryStatus.BOOKED);
        d.setPrice(calculatePrice(req));

        d.setPkg(pkg);
        d.setSenderAddress(req.getSenderAddress());
        d.setReceiverAddress(req.getReceiverAddress());

        Delivery saved = repo.save(d);

      

        return saved;
    }

   
    public List<Delivery> getUserDeliveries(String userId) {
        return repo.findByUserId(userId);
    }

