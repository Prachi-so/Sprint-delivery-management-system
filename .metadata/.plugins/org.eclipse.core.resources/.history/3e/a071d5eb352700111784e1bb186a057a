package com.example.demo.controller;

import java.io.File;
import java.io.IOException;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.core.io.FileSystemResource;
import org.springframework.core.io.Resource;
import org.springframework.http.HttpHeaders;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;
import org.springframework.web.multipart.MultipartFile;

import com.example.demo.entity.DeliveryProof;
import com.example.demo.entity.Document;
import com.example.demo.entity.TrackingEvent;
import com.example.demo.repository.DeliveryProofRepository;
import com.example.demo.repository.DocumentRepository;
import com.example.demo.service.FileService;
import com.example.demo.service.TrackingService;

@RestController
@RequestMapping("/tracking")
public class TrackingController {

	@Autowired
    private TrackingService service;

    @Autowired
    private FileService fileService;

    @Autowired
    private DocumentRepository documentRepo;

    @Autowired
    private DeliveryProofRepository proofRepo;

    // 🔥 EVENT
    @PostMapping("/event")
    public TrackingEvent createEvent(@RequestBody TrackingEvent event) {
        return service.createEvent(event);
    }

    @GetMapping("/events/{deliveryId}")
    public List<TrackingEvent> getEvents(@PathVariable Long deliveryId) {
        return service.getEvents(deliveryId);
    }

    // 📄 UPLOAD DOCUMENT
    @PostMapping("/document/upload")
    public Document uploadDocument(
            @RequestParam MultipartFile file,
            @RequestParam Long deliveryId,
            @RequestParam String userId,
            @RequestParam String docType) throws IOException {

        String path = fileService.saveFile(file);

        Document doc = new Document();
        doc.setDeliveryId(deliveryId);
        doc.setUserId(userId);
        doc.setDocType(docType);
        doc.setFileUrl(path);
        doc.setFileName(file.getOriginalFilename());

        return service.saveDocument(doc);
    }

    // 📄 GET DOCUMENT
    @GetMapping("/document/{id}")
    public ResponseEntity<Resource> getDocument(@PathVariable Long id) {

    	Document doc = documentRepo.findById(id)
                .orElseThrow(() -> new RuntimeException("Not found"));

        String fullPath = System.getProperty("user.dir") + File.separator + doc.getFileUrl();

        File file = new File(fullPath);

        return ResponseEntity.ok()
                .header(HttpHeaders.CONTENT_DISPOSITION,
                        "attachment; filename=\"" + doc.getFileName() + "\"")
                .body(new FileSystemResource(file));
    }

    // 📸 UPLOAD PROOF
    @PostMapping("/proof/upload")
    public DeliveryProof uploadProof(
            @RequestParam MultipartFile file,
            @RequestParam Long deliveryId,
            @RequestParam String userId,
            @RequestParam String proofType) throws IOException {

        String path = fileService.saveFile(file);

        DeliveryProof proof = new DeliveryProof();
        proof.setDeliveryId(deliveryId);
        proof.setUserId(userId);
        proof.setProofType(proofType);
        proof.setImageUrl(path);

        return service.saveProof(proof);
    }

    // 📸 VIEW IMAGE
    @GetMapping("/proof/{id}")
    public ResponseEntity<Resource> getProof(@PathVariable Long id) {

    	

    	    DeliveryProof proof = proofRepo.findById(id)
    	            .orElseThrow(() -> new RuntimeException("Not found"));

    	    String fullPath = System.getProperty("user.dir") + File.separator + proof.getImageUrl();

    	    File file = new File(fullPath);

    	    return ResponseEntity.ok()
    	            .contentType(MediaType.IMAGE_JPEG)
    	            .body(new FileSystemResource(file));
    	}
    }

